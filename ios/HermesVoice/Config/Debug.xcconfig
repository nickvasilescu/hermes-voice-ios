// Safe public defaults. Xcode treats `//` as a comment, so URL schemes use
// `/$()/`. Simulator builds can reach a bridge running on the same Mac.
BRIDGE_BASE_URL = http:/$()/127.0.0.1:8787
PRODUCT_BUNDLE_IDENTIFIER = com.example.HermesVoice

// Copy Local.xcconfig.example to Local.xcconfig for a physical device or a
// deployed bridge. Local.xcconfig is gitignored and must never contain API
// keys or bearer tokens.
#include? "Local.xcconfig"
