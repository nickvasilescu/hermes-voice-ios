# Copy to bridge/.env and fill in real values for local development.
# `node --env-file=.env` (used by `make bridge-dev` / `npm run dev`) loads
# this file. Nothing in this repo reads a repo-root .env automatically —
# the file lives under bridge/ because that's the process that consumes it.
#
# NEVER commit a real .env file. It is gitignored on purpose.

# --- Server ---
NODE_ENV=development
PORT=8787

# --- OpenAI Realtime ---
# Required for POST /v1/realtime/session to mint real ephemeral credentials.
# Leave unset and set BRIDGE_MOCK_OPENAI=1 to exercise the rest of the stack
# without an OpenAI account (dev only — never in production).
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime-2.1
OPENAI_REALTIME_URL=https://api.openai.com/v1/realtime/client_secrets
BRIDGE_MOCK_OPENAI=0

# --- Client-session bootstrap ---
# Optional outside production, required in production. This server-held
# credential gates POST /v1/session only. It must never be bundled in the iOS
# app. A real deployment should put login/device attestation in front of this
# endpoint instead of distributing this static bootstrap secret to clients.
BRIDGE_BOOTSTRAP_SECRET=
BRIDGE_SESSION_TTL_MS=86400000
BRIDGE_SESSION_MAX_ENTRIES=1000

# --- Bounded development storage ---
BRIDGE_TASK_TTL_MS=86400000
BRIDGE_TASK_MAX_ENTRIES=1000
BRIDGE_IDEMPOTENCY_TTL_MS=86400000
BRIDGE_IDEMPOTENCY_MAX_ENTRIES=1000

# --- CORS ---
# Comma-separated list of allowed origins. Empty + NODE_ENV=development is
# permissive (reflects any origin); empty + NODE_ENV=production denies all
# cross-origin requests.
BRIDGE_CORS_ALLOWLIST=

# --- Rate limiting ---
BRIDGE_RATE_LIMIT_MAX=60
BRIDGE_RATE_LIMIT_WINDOW_MS=60000

# --- SSE ---
BRIDGE_SSE_PING_MS=15000

# --- Hermes API Server (real provider) ---
# When both are set, the bridge uses ApiServerHermesProvider against Hermes'
# runs API instead of MockHermesProvider. Point base URL at the Hermes gateway
# API server (default port 8642). Never commit a real API_SERVER_KEY.
# HERMES_API_BASE_URL=http://127.0.0.1:8642
# HERMES_API_KEY=
# Optional extra instructions layered onto every run:
# HERMES_API_INSTRUCTIONS=
