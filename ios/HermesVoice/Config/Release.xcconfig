// Public placeholder only. Set a reachable HTTPS bridge URL and unique bundle
// identifier in gitignored Local.xcconfig before archiving. Never put an API
// key, bootstrap secret, or bearer token in an xcconfig.
BRIDGE_BASE_URL = https:/$()/your-bridge.example.com
PRODUCT_BUNDLE_IDENTIFIER = com.example.HermesVoice
#include? "Local.xcconfig"
